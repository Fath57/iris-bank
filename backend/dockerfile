# Utiliser une image Node.js officielle (Debian-based pour meilleure compatibilité)
FROM node:22

# Définir le répertoire de travail
WORKDIR /app

# Copier les fichiers de dépendances
COPY package.json ./

# Configurer npm pour ne pas vérifier strictement SSL (pour résoudre les problèmes de certificat)
# et installer les dépendances
RUN npm config set strict-ssl false && \
    npm install --legacy-peer-deps

# Copier le reste du code source
COPY . .

# Générer le client Prisma
RUN npx prisma generate

# Exposer le port de l'application
EXPOSE 5001

# La commande de démarrage
CMD ["npm", "run", "dev"]