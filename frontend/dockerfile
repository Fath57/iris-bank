# Utiliser une image Node.js officielle (Debian-based pour meilleure compatibilité)
FROM node:22

# Définir le répertoire de travail
WORKDIR /app

# Copier les fichiers de dépendances
COPY package.json package-lock.json ./

# Configurer npm pour ne pas vérifier strictement SSL et installer les dépendances
RUN npm config set strict-ssl false && \
    npm install

# Copier le reste du code source
COPY . .

# Exposer le port Vite
EXPOSE 5173

# Démarrer le serveur de développement avec --host pour accepter les connexions externes
CMD ["npm", "run", "dev", "--", "--host"]